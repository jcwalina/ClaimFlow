generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedClaims Claim[]      @relation("AssignedClaims")
  assignedTasks  Task[]       @relation("AssignedTasks")
  notes          ClaimNote[]
  auditEvents    AuditEvent[]
}

model Claim {
  id            String    @id @default(cuid())
  claimantName  String
  policyNumber  String
  claimType     String    @default("GENERAL")
  icdCode       String?
  dateOfService DateTime?
  amountClaimed Float?
  description   String?
  status        String
  priority      String
  assignedToId  String?
  assignedTo    User?     @relation("AssignedClaims", fields: [assignedToId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  notes       ClaimNote[]
  auditEvents AuditEvent[]
  attachments ClaimAttachment[]
  tasks       Task[]
}

model ClaimAttachment {
  id        String   @id @default(cuid())
  claimId   String
  claim     Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
}

model ClaimNote {
  id        String   @id @default(cuid())
  claimId   String
  claim     Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  text      String
  createdAt DateTime @default(now())
}

model Task {
  id           String    @id @default(cuid())
  claimId      String
  claim        Claim     @relation(fields: [claimId], references: [id], onDelete: Cascade)
  type         String
  title        String
  dueDate      DateTime?
  status       String    @default("OPEN")
  assignedToId String?
  assignedTo   User?     @relation("AssignedTasks", fields: [assignedToId], references: [id])
  createdAt    DateTime  @default(now())
}

model AuditEvent {
  id        String   @id @default(cuid())
  claimId   String?
  claim     Claim?   @relation(fields: [claimId], references: [id], onDelete: SetNull)
  actorId   String
  actor     User     @relation(fields: [actorId], references: [id])
  type      String
  metadata  Json
  createdAt DateTime @default(now())
}
